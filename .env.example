# ===========================================
# 股票分析系统 - 环境变量配置示例
# ===========================================

# -------------------------------------------
# 数据源配置 - 优先级 (数字越小优先级越高)
# -------------------------------------------
# 0: FUTU (富途 API) - 需要账户和 OpenD
# 1: SINA_HK (新浪港股) - 免费实时
# 2: EASTMONEY (东方财富) - 免费实时
# 3: AKSHARE (AkShare) - 免费
# 4: FINNHUB (Finnhub) - 需要 API Key
# 5: YAHOO_FINANCE (Yahoo Finance) - 免费

# -------------------------------------------
# 富途 API 配置 (推荐，需要富途账户)
# -------------------------------------------
FUTU_ENABLED=false
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_RSA_KEY_PATH=

# -------------------------------------------
# 新浪港股配置 (免费，推荐)
# -------------------------------------------
SINA_HK_ENABLED=true

# -------------------------------------------
# 东方财富配置 (免费，推荐)
# -------------------------------------------
EASTMONEY_ENABLED=true

# -------------------------------------------
# AkShare 配置 (免费，推荐)
# -------------------------------------------
AKSHARE_ENABLED=true

# -------------------------------------------
# Finnhub 配置 (需要 API Key)
# -------------------------------------------
FINNHUB_ENABLED=false
FINNHUB_API_KEY=

# -------------------------------------------
# Yahoo Finance 配置 (免费，备选)
# -------------------------------------------
YAHOO_FINANCE_ENABLED=true

# -------------------------------------------
# 其他数据源 (可选)
# -------------------------------------------
ALPHA_VANTAGE_ENABLED=false
ALPHA_VANTAGE_API_KEY=

FMP_ENABLED=false
FMP_API_KEY=

TWELVE_DATA_ENABLED=false
TWELVE_DATA_API_KEY=

RAPIDAPI_ENABLED=false
RAPIDAPI_KEY=

# -------------------------------------------
# 缓存配置
# -------------------------------------------
DATA_CACHE_TTL=3600
DATA_SOURCE_MAX_RETRIES=3
DATA_SOURCE_RETRY_DELAY=1.0
DATA_SOURCE_FALLBACK_ENABLED=true

# -------------------------------------------
# 日志配置
# -------------------------------------------
LOG_LEVEL=INFO
DEBUG=false
